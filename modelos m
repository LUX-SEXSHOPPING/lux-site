<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Modelos Masculinos — LUX</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@1,600&display=swap" rel="stylesheet">
    <style>
        :root {
            --dourado: #c9a227;
            --texto-claro: #f0e9ec;
            --texto-suave: #e0d8dc;
            --whatsapp-verde: #25d366;
        }
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body {
            font-family: 'Segoe UI', sans-serif;
            color: var(--texto-claro);
            /* ✅ Fundo: banner.png */
            background: linear-gradient(rgba(8,6,8,.4), rgba(15,8,15,.45)), url('banner.png');
            background-size: cover;
            background-position: center;
            background-attachment: fixed;
        }
        header {
            background: rgba(8,6,8,.6);
            border-bottom: 1px solid rgba(201,162,39,.1);
            padding: 1rem;
            display: flex;
            justify-content: space-between;
            align-items: center;
            flex-wrap: wrap;
            position: sticky;
            top: 0;
            z-index: 100;
        }
        .logo {
            font-size: 1.4rem;
            font-weight: 700;
            color: var(--dourado);
            letter-spacing: 2px;
        }
        nav a {
            color: var(--texto-suave);
            text-decoration: none;
            margin: 0 .6rem;
            font-weight: 500;
        }
        nav a:hover { color: var(--dourado); }
        main {
            padding: 2rem 1rem;
            max-width: 1000px;
            margin: 0 auto;
        }
        h1 {
            font-family: 'Playfair Display', serif;
            font-style: italic;
            color: var(--dourado);
            text-align: center;
            margin-bottom: 2rem;
        }
        .icone-masculino {
            display: inline-block;
            width: 22px;
            height: 22px;
            background: linear-gradient(180deg, #4a90e2 0%, #2563eb 40%, #1d4ed8 100%);
            border-radius: 50%;
            box-shadow: inset 0 -3px 6px rgba(255,255,255,.3);
            vertical-align: middle;
            margin-right: 8px;
        }
        .galeria {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
            gap: 1.8rem;
        }
        .card {
            background: rgba(0,0,0,.25);
            border-radius: 12px;
            overflow: hidden;
            border: 1px solid rgba(201,162,39,.15);
            transition: transform .3s, box-shadow .3s;
        }
        .card:hover {
            transform: translateY(-5px);
            box-shadow: 0 8px 20px rgba(0,0,0,.3);
        }
        /* ✅ Foto */
        .card img {
            width: 100%;
            height: 340px;
            object-fit: cover;
            display: block;
            background: #111;
        }
        .card p {
            text-align: center;
            padding: 1rem 1rem .3rem;
            color: var(--texto-suave);
            font-weight: 600;
            font-size: 1.1rem;
            margin: 0;
        }
        .card small {
            display: block;
            text-align: center;
            color: #aaa;
            padding: 0 .5rem .8rem;
        }
        .botao-whats-modelo {
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
            background: var(--whatsapp-verde);
            color: #fff;
            text-decoration: none;
            font-weight: 600;
            padding: .6rem 1rem;
            margin: 0 auto 1.2rem;
            border-radius: 6px;
            width: fit-content;
            transition: background .3s, transform .2s;
        }
        .botao-whats-modelo:hover {
            background: #1fb855;
            transform: scale(1.05);
        }
        footer {
            text-align: center;
            padding: 1.5rem;
            color: #887c80;
            font-size: .9rem;
            background: rgba(8,6,8,.5);
            border-top: 1px solid rgba(201,162,39,.06);
        }
        .rodape-frase {
            color: #b89a2f;
            margin-top: .5rem;
            font-style: italic;
        }
        @media (max-width: 600px) {
            .galeria { grid-template-columns: 1fr; }
            header { flex-direction: column; gap: 1rem; }
            .card img { height: 300px; }
        }
    </style>
</head>
<body>

<header>
    <div class="logo"><span class="icone-masculino"></span>Modelos Masculinos</div>
    <nav><a href="index.html">← Voltar ao Início</a></nav>
</header>

<main>
    <h1><span class="icone-masculino"></span>Modelos Selecionados</h1>

    <div class="galeria">
        <!-- ✅ Modelo 1 -->
        <div class="card">
            <img src="garoto1.jpg" alt="Leonardo">
            <p>Leonardo</p>
            <small>Carisma • Presença • Estilo</small>
            <a class="botao-whats-modelo"
               href="https://wa.me/5551980612941?text=Olá!%20Gostaria%20de%20saber%20mais%20sobre%20o%20modelo%20*Leonardo*%20da%20LUX."
               target="_blank">
                <i class="fa-brands fa-whatsapp"></i> Falar com Leonardo
            </a>
        </div>

        <!-- ✅ Modelo 2 -->
        <div class="card">
            <img src="garoto2.jpg" alt="Thiago">
            <p>Thiago</p>
            <small>Força • Beleza • Sofisticação</small>
            <a class="botao-whats-modelo"
               href="https://wa.me/5551980612941?text=Olá!%20Gostaria%20de%20saber%20mais%20sobre%20o%20modelo%20*Thiago*%20da%20LUX."
               target="_blank">
                <i class="fa-brands fa-whatsapp"></i> Falar com Thiago
            </a>
        </div>

        <!-- ✅ Modelo 3 -->
        <div class="card">
            <img src="garoto3.jpg" alt="Rodrigo">
            <p>Rodrigo</p>
            <small>Elegância • Charme • Discrição</small>
            <a class="botao-whats-modelo"
               href="https://wa.me/5551980612941?text=Olá!%20Gostaria%20de%20saber%20mais%20sobre%20o%20modelo%20*Rodrigo*%20da%20LUX."
               target="_blank">
                <i class="fa-brands fa-whatsapp"></i> Falar com Rodrigo
            </a>
        </div>
    </div>
</main>

<footer>
    <p>© 2026 LUX — Proibido para menores de 18 anos.</p>
    <p class="rodape-frase"><strong>LUX:</strong> Todos os direitos pertencem exclusivamente à marca.</p>
</footer>

</body>
</html>
